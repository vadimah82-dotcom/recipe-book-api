[flake8]
max-line-length = 100
# E203 (whitespace before ':') и W503 (line break before binary operator)
# конфликтуют с форматированием black — отключаем их, как рекомендует
# сама документация black: https://black.readthedocs.io/en/stable/guides/using_black_with_other_tools.html
extend-ignore = E203, W503
exclude = .git,__pycache__,.venv,venv,build,dist
